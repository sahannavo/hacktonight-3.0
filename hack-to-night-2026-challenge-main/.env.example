# ─── Database Configuration ─────────────────────────────────────────
# SECURITY FIX: No hardcoded passwords. Replace with your actual credentials.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<your-secure-password-here>
POSTGRES_DB=htn26db

# For local dev (Docker Compose):
# DATABASE_URL=postgresql://postgres:<your-password>@db:5432/htn26db
# For local dev (direct):
# DATABASE_URL=postgresql://postgres:<your-password>@localhost:5432/htn26db
DATABASE_URL=postgresql://postgres:<your-secure-password-here>@localhost:5432/htn26db

# ─── Application Security ───────────────────────────────────────────
# Set to "production" for live deployments (enforces Secure cookie flag, sanitizes errors)
NODE_ENV=development

# Session cookie max age in seconds (default: 7 days = 604800)
SESSION_MAX_AGE=604800

# HMAC signing secret for session tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=<generate-a-secure-random-string>

# Add any additional environment variables your team needs below
